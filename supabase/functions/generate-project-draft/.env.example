// supabase/config.toml example for deno.json configuration

// For proper deno support with supabase, ensure your deno.json includes:
{
  "imports": {
    "std/": "https://deno.land/std@0.208.0/",
    "@supabase/": "https://cdn.jsdelivr.net/gh/supabase/supabase-js@v2/dist/",
    "zod": "https://deno.land/x/zod@v3.22.4/mod.ts"
  }
}

// Commands:

// 1. Deploy the Edge Function:
// supabase functions deploy generate-project-draft

// 2. Test locally (requires local supabase setup):
// supabase start
// supabase functions serve generate-project-draft

// 3. Set OpenAI API key:
// supabase secrets set OPENAI_API_KEY=sk_live_...

// 4. View Edge Function logs:
// supabase functions logs generate-project-draft

// Environment variables needed in Supabase:
// - OPENAI_API_KEY: Your OpenAI API key (required for production)

// CORS is handled in the Edge Function with appropriate headers
// All authenticated users can call the function

// Rate limiting should be added at the API Gateway level for production
